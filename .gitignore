*.so
*.egg-info/
dist/
build/
eggs/
*.egg
.python-version

# Virtual environments
venv/
.venv/
backend/.venv/

# Django
db.sqlite3
media/
staticfiles/
*.log
*.pot

# Byte-compiled / optimized / DLL files
*.pyc
*.pyo
*.pyd

# Test and coverage
.pytest_cache/
coverage/
htmlcov/
*.cover
.coverage

# Node / frontend
node_modules/
frontend/node_modules/
dist/
build/

# Vite / npm
/.vite

# Environment files
.env
.env.*

# IDEs and editors
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log

# Misc
*.iml
npm-debug.log*
yarn-debug.log*
yarn-error.log*

