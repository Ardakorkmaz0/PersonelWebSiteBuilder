# Copy this file to backend/.env and edit. Anything you leave out falls
# back to the dev-friendly default in config/settings.py.

# Dev defaults — uncomment for prod.
# DJANGO_DEBUG=False

# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(60))"
# DJANGO_SECRET_KEY=replace-me

# Comma-separated. REQUIRED in production.
# DJANGO_ALLOWED_HOSTS=builder.example.com,www.example.com

# Database. Defaults to SQLite. For Postgres:
# DATABASE_URL=postgres://builder:secret@db:5432/builder

# Where the editor frontend is hosted. Adjust to your prod origin.
# DJANGO_CORS_ORIGINS=https://builder.example.com

# Optional: switch CSP into report-only mode while testing a new policy.
# DJANGO_CSP_REPORT_ONLY=True

# Optional: enable Sentry for error reporting.
# SENTRY_DSN=https://your-dsn@o1.ingest.sentry.io/123
# SENTRY_TRACES_SAMPLE_RATE=0.05

# Force HTTPS — only off if you're terminating TLS somewhere else.
# DJANGO_SSL_REDIRECT=True

# HSTS lifetime in seconds. 1 year by default.
# DJANGO_HSTS_SECONDS=31536000
