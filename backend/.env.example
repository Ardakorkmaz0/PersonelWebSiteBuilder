# Copy this file to backend/.env and edit. Anything you leave out falls
# back to the dev-friendly default in config/settings.py.

# Dev defaults — uncomment for prod.
# DJANGO_DEBUG=False

# REQUIRED in production. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(60))"
# DJANGO_SECRET_KEY=replace-me

# Comma-separated. REQUIRED in production.
# DJANGO_ALLOWED_HOSTS=builder.example.com,www.example.com

# Database. Defaults to SQLite. For Postgres:
# DATABASE_URL=postgres://builder:secret@db:5432/builder

# Optional: Redis — when set, DRF rate-limit counters (and any caching) are
# shared across gunicorn workers instead of living per-process. Recommended in
# prod so throttling is accurate behind multiple workers. Needs the `redis` pkg.
# REDIS_URL=redis://redis:6379/0

# Optional: tune the rate limits (defaults shown). `auth` guards the
# register/login/google endpoints against brute-force + signup spam.
# DJANGO_THROTTLE_ANON=120/min
# DJANGO_THROTTLE_USER=6000/hour
# DJANGO_THROTTLE_AUTH=10/min

# Where the editor frontend is hosted. Adjust to your prod origin.
# DJANGO_CORS_ORIGINS=https://builder.example.com

# Optional: switch CSP into report-only mode while testing a new policy.
# DJANGO_CSP_REPORT_ONLY=True

# Optional: Google sign-in (env-gated — leave unset to disable). Create an OAuth
# 2.0 Web client at https://console.cloud.google.com/apis/credentials, add your
# frontend origin (e.g. http://localhost:5173) to "Authorized JavaScript origins",
# then put the SAME client id here AND in frontend/.env (VITE_GOOGLE_CLIENT_ID).
# GOOGLE_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# Optional: reCAPTCHA v2 "I'm not a robot" (env-gated). Get a v2 Checkbox key pair
# at https://www.google.com/recaptcha/admin — put the SECRET here and the SITE key
# in frontend/.env (VITE_RECAPTCHA_SITE_KEY).
# RECAPTCHA_SECRET_KEY=your-recaptcha-secret

# Optional: enable Sentry for error reporting.
# SENTRY_DSN=https://your-dsn@o1.ingest.sentry.io/123
# SENTRY_TRACES_SAMPLE_RATE=0.05

# Force HTTPS — only off if you're terminating TLS somewhere else.
# DJANGO_SSL_REDIRECT=True

# HSTS lifetime in seconds. 1 year by default.
# DJANGO_HSTS_SECONDS=31536000
