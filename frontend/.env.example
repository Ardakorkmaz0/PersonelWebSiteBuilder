# Copy to frontend/.env and edit. All optional — defaults work for local dev.

# Backend API base. Defaults to http://127.0.0.1:8000/api.
# VITE_API_URL=http://127.0.0.1:8000/api

# Google sign-in (env-gated): the OAuth 2.0 Web client id. Use the SAME id as the
# backend's GOOGLE_OAUTH_CLIENT_ID. Leave unset to hide the Google button.
# VITE_GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com

# reCAPTCHA v2 "I'm not a robot" (env-gated): the SITE key (the backend holds the
# matching RECAPTCHA_SECRET_KEY). Leave unset to hide the captcha.
# VITE_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
